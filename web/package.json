{
  "name": "openclaw-cn-manager",
  "version": "1.0.0",
  "description": "OpenClaw-CN Manager - 一站式安装与管理系统",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node ..\\scripts\\kill-manager-before-dev.cjs && cd ..\\src-tauri && node ..\\web\\node_modules\\@tauri-apps\\cli\\tauri.js dev -- --no-default-features",
    "tauri:build": "node ..\\scripts\\kill-manager-before-dev.cjs && cd ..\\src-tauri && node ..\\web\\node_modules\\@tauri-apps\\cli\\tauri.js build"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.10.9",
    "ansi-to-html": "^0.7.2",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.4",
    "yaml": "^2.5.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/cli": "^2.1.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
