{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "快泛claw",
  "version": "1.0.23",
  "identifier": "com.mimo.kuaifan-claw",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": null,
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../web/dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCMUY2NzgxQTZGNDA5NDUKUldSRkNmU21nV2NmYXpyYURvOHJYZjhiRGRpV09JczlmUFFSZHVuZ1JnaXhuMzczbXljSEdyczQK",
      "endpoints": [
        "https://MiMo-ts.github.io/kuaifan-claw/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "快泛claw",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "快泛claw 一站式安装与管理工具",
    "longDescription": "快泛claw — 一站式安装与管理系统，支持多平台、多通道机器人网关管理。",
    "category": "DeveloperTool",
    "resources": [
      "bundled-env/*",
      "bundled-openclaw/*",
      "resources/data",
      "resources/skills-env",
      "resources/plugins"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerHooks": "./windows/hooks.nsi",
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null
    }
  }
}
